{
  "name": "ixc-integration-api",
  "version": "1.0.0",
  "description": "IXC Integration API - Fase 1",
  "main": "backend/dist/server.js",
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "dev:full": "concurrently -n frontend,backend -c magenta,cyan \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "npm run build:frontend && npm run build:backend",
    "build:dev": "npm run build:frontend",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "build:backend": "tsc -p backend/tsconfig.json",
    "preview": "vite preview --config frontend/vite.config.ts",
    "dev:backend": "tsx watch backend/src/server.ts",
    "start": "node backend/dist/server.js",
    "start:backend": "node backend/dist/server.js",
    "test": "vitest run --config backend/vitest.config.ts",
    "test:watch": "vitest --config backend/vitest.config.ts",
    "test:coverage": "vitest run --config backend/vitest.config.ts --coverage",
    "typecheck": "npm run typecheck:frontend && npm run typecheck:backend",
    "typecheck:frontend": "tsc --noEmit -p frontend/tsconfig.json",
    "typecheck:backend": "tsc --noEmit -p backend/tsconfig.json"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.2.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.100.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "3.7.2",
    "autoprefixer": "10.4.20",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "fastify": "^4.26.0",
    "ioredis": "^5.3.2",
    "lucide-react": "^1.7.0",
    "pg": "^8.11.3",
    "postcss": "8.4.49",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^1.2.0",
    "concurrently": "^9.2.1",
    "supertest": "^6.3.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
