{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run build:frontend",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/version.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "max-age=0, s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/users/me",
      "destination": "/api/users?__me=1"
    },
    {
      "source": "/users",
      "destination": "/api/users"
    },
    {
      "source": "/users/(.*)/disconnect",
      "destination": "/api/users/[id]?id=$1"
    },
    {
      "source": "/users/(.*)",
      "destination": "/api/users/[id]?id=$1"
    },
    {
      "source": "/tenants",
      "destination": "/api/settings?__tenants=1"
    },
    {
      "source": "/settings",
      "destination": "/api/settings"
    },
    {
      "source": "/settings/ixc/connections/(.*)/activate",
      "destination": "/api/settings/ixc-connections/[id]?id=$1"
    },
    {
      "source": "/settings/ixc/connections/(.*)",
      "destination": "/api/settings/ixc-connections/[id]?id=$1"
    },
    {
      "source": "/settings/ixc/connections",
      "destination": "/api/settings/ixc-connections"
    },
    {
      "source": "/campaign/legacy-redemptions",
      "destination": "/api/campaign/legacy-redemptions"
    },
    {
      "source": "/campaign/legacy-redemptions/(.*)",
      "destination": "/api/campaign/legacy-redemptions/[id]?id=$1"
    },
    {
      "source": "/campaign/manual-points",
      "destination": "/api/campaign/manual-points"
    },
    {
      "source": "/campaign/rule-settings",
      "destination": "/api/campaign/rule-settings"
    },
    {
      "source": "/campaign/rule-settings/(.*)",
      "destination": "/api/campaign/rule-settings/[id]?id=$1"
    },
    {
      "source": "/campaign/catalog",
      "destination": "/api/campaign/catalog"
    },
    {
      "source": "/campaign/catalog/(.*)",
      "destination": "/api/campaign/catalog/[id]?id=$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
